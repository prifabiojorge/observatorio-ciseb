# Supabase
SUPABASE_URL=https://yefudgudlpjctmdjkkio.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx          # APENAS no Render
SUPABASE_ANON_KEY=eyJxxxxx                  # Vercel + Render

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Telegram
TELEGRAM_BOT_TOKEN=SEU_TELEGRAM_BOT_TOKEN_AQUI
TELEGRAM_CHAT_ID_FABIO=SEU_CHAT_ID_AQUI

# Resend
RESEND_API_KEY=re_xxxxx
RESEND_FROM=observatorio@ciseb.edu.br

# App
APP_ENV=production
APP_TIMEZONE=America/Fortaleza
NEWSLETTER_SCHEDULE=0 7 * * 1-5
TOPN_DAILY=10

# Cron Secret (Vercel + Render) — ⚠️ OBRIGATÓRIO, sem fallback
# Gere um valor aleatório forte (ex: `openssl rand -hex 32`).
# Deve ser IGUAL no Render e na Vercel.
CRON_SECRET=seu-cron-secret-aqui

# Token público do dashboard (client-side). NÃO é segurança real —
# apenas barreira contra acesso casual. Para segurança real: Supabase Auth.
NEXT_PUBLIC_DASHBOARD_TOKEN=seu-dashboard-token-aqui

# Render
RENDER_SERVICE_ID=srv-xxxxxxxxx
RENDER_DEPLOY_URL=https://seu-app.onrender.com

# HuggingFace (embeddings BGE-M3 via Inference API — Opção D)
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Vercel (Next.js App Router) — variáveis específicas
# ⚠️ Estas variáveis são injetadas no ambiente da Vercel.
#    NÃO comitar valores reais — usar Vercel Environment Variables.
# ─────────────────────────────────────────────────────────────

# URLs dos endpoints do Render Web Service — ⚠️ OBRIGATÓRIO, sem fallback
RENDER_RUN_URL=https://seu-app.onrender.com/run
RENDER_DIGEST_URL=https://seu-app.onrender.com/digest

# ⚠️ Exceção MVP: SERVICE_ROLE_KEY também é necessária na Vercel
# para as rotas /api/findings/decide e /api/findings/pending.
# Em produção, migrar para Supabase Edge Functions ou BFF com Auth.
# SUPABASE_SERVICE_ROLE_KEY (já definido acima)
# SUPABASE_URL e SUPABASE_ANON_KEY (já definidos acima)
