+        outline: "none",
+    },
+    button: {
+        padding: "12px 16px",
+        background: "#007bff",
+        color: "#fff",
+        border: "none",
+        borderRadius: 6,
+        cursor: "pointer",
+        fontWeight: 600,
+        fontSize: 14,
+    },
+    divider: {
+        textAlign: "center",
