+        maxWidth: 400,
+    },
+    title: { margin: "0 0 8px 0", fontSize: 24, fontWeight: 700 },
+    subtitle: { margin: "0 0 24px 0", color: "#666", fontSize: 14 },
+    form: { display: "flex", flexDirection: "column", gap: 12 },
+    input: {
+        padding: "12px 16px",
